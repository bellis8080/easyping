# .dockerignore - Files to exclude from Docker build context
# This significantly reduces build time and image size

# Dependencies
node_modules
**/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
.next
**/. next
dist
**/dist
build
**/build
out
**/out
*.tsbuildinfo
**/*.tsbuildinfo

# Git
.git
.gitignore
.gitattributes

# Environment files
.env
.env.local
.env*.local
**/.env
**/.env.local
**/.env*.local

# IDE / Editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Documentation
*.md
!README.md
docs
**/docs

# Testing
coverage
**/ coverage
.nyc_output
**/.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
**/__tests__
**/__mocks__
**/tests
.vitest

# CI/CD
.github
.husky
.gitlab-ci.yml
.travis.yml
.circleci

# Turborepo
.turbo
**/.turbo

# Docker
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# Supabase (local development)
supabase/.branches
supabase/.temp
**/supabase/.branches
**/supabase/.temp

# Backup files
*.sql
**/backups

# Logs
logs
*.log

# OS
Thumbs.db

# Misc
.cache
tmp
temp
.temporary
