# =============================================================================
# EasyPing Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# -----------------------------------------------------------------------------
# Supabase Configuration (Story 1.2)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings: https://app.supabase.com
# For local development, run: pnpm supabase:start

# Public URL for Supabase API (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Public anonymous key (safe to expose to browser)
# This key has Row Level Security (RLS) policies applied
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key (NEVER expose to browser, server-side only)
# This key bypasses RLS - use with extreme caution
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Public URL of your application
# Used for callbacks, email links, and API routes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (development | production | test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# AI Provider Configuration (Story 3.1 - Optional)
# -----------------------------------------------------------------------------
# AI providers are used for intelligent ticket routing and categorization
# Configure via UI in Story 3.2, or set here for development

# AI Provider: openai | anthropic | azure
# AI_PROVIDER=openai

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=1000

# Anthropic Configuration
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_MAX_TOKENS=1000

# Azure OpenAI Configuration
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# -----------------------------------------------------------------------------
# Email Configuration (Story 1.3 - Optional)
# -----------------------------------------------------------------------------
# Email is used for auth, notifications, and ticket replies
# Supabase handles auth emails by default

# SMTP settings for custom email provider (optional)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=EasyPing

# -----------------------------------------------------------------------------
# Feature Flags (Story 2.1+)
# -----------------------------------------------------------------------------
# Enable/disable features during development

# Enable AI-powered features (Story 3.1+)
NEXT_PUBLIC_FEATURE_AI_ENABLED=false

# Enable real-time updates via Supabase Realtime (Story 2.3)
NEXT_PUBLIC_FEATURE_REALTIME_ENABLED=true

# Enable file attachments in tickets (Story 2.2)
NEXT_PUBLIC_FEATURE_ATTACHMENTS_ENABLED=false

# -----------------------------------------------------------------------------
# Analytics & Monitoring (Story 1.7 - Optional)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=

# PostHog API key for product analytics
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Development & Debugging
# -----------------------------------------------------------------------------

# Enable verbose logging (true | false)
DEBUG=false

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Disable telemetry (Next.js, Turborepo)
NEXT_TELEMETRY_DISABLED=1
TURBO_TELEMETRY_DISABLED=1

# Bundle analyzer (run: pnpm analyze)
# ANALYZE=false
