# Supabase Configuration
# Get these values by running: npx supabase status

# Public Supabase URL (local development)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Public Supabase Anonymous Key (local development)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Supabase Service Role Key (for admin operations, bypasses RLS)
# IMPORTANT: Never commit this key or expose it to the client
SUPABASE_SERVICE_ROLE_KEY=sb_secret_N7UND0UgjKTVK-Uodkm0Hg_xSvEMPvz

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Encryption Key for AI API Keys (Story 1.6)
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this secure and consistent across deployments
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Additional local development URLs (for reference)
# Database URL: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Studio URL: http://127.0.0.1:54323
# Mailpit URL: http://127.0.0.1:54324 (view test emails here)

# Email Configuration
# Local development uses Supabase's built-in email via Mailpit
# View sent emails at: http://127.0.0.1:54324
# No additional SMTP configuration needed for local development

# Production SMTP Configuration (Optional)
# Uncomment and configure these for production email delivery:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key-here
# SMTP_FROM_EMAIL=noreply@easyping.com
# SMTP_FROM_NAME=EasyPing
