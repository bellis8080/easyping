# EasyPing Docker Compose Environment Configuration
# Copy this file to .env and fill in the values
# WARNING: DO NOT commit .env file with real secrets to version control!

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=postgres

# How to generate a secure password:
# openssl rand -base64 32

# =============================================================================
# Supabase Auth (GoTrue) Configuration
# =============================================================================

# JWT Secret - MUST be same as PGRST_JWT_SECRET
# Generate with: openssl rand -base64 32
GOTRUE_JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# JWT expiration in seconds (default: 3600 = 1 hour)
GOTRUE_JWT_EXP=3600

# Site URL - Your application's public URL
GOTRUE_SITE_URL=http://localhost

# Allow list for redirect URLs (comma-separated)
GOTRUE_URI_ALLOW_LIST=*

# Disable public signup (set to true for invite-only)
GOTRUE_DISABLE_SIGNUP=false

# Email Authentication
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=false

# SMTP Configuration (optional, required for email verification)
GOTRUE_SMTP_ADMIN_EMAIL=admin@example.com
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=EasyPing

# Google OAuth Configuration (optional)
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=http://localhost/auth/v1/callback

# =============================================================================
# PostgREST Configuration
# =============================================================================

# Database schema to expose via REST API
PGRST_DB_SCHEMAS=public

# Anonymous role for unauthenticated requests
PGRST_DB_ANON_ROLE=anon

# =============================================================================
# Supabase Storage Configuration
# =============================================================================

# Storage backend (file or s3)
STORAGE_BACKEND=file

# Maximum file size in bytes (default: 50MB)
FILE_SIZE_LIMIT=52428800

# =============================================================================
# Supabase Realtime Configuration
# =============================================================================

# Secret key base for Realtime service
# Generate with: openssl rand -base64 64
REALTIME_SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa3OFWdYdNvE7OvkbokLdcNYP

# =============================================================================
# Supabase API Keys
# =============================================================================

# Anonymous Key - Public key for client-side usage
# Generate JWT with role 'anon' using GOTRUE_JWT_SECRET
# You can use: https://supabase.com/docs/guides/hosting/overview#api-keys
# Or generate using: https://jwt.io
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Service Role Key - Secret key for server-side usage with elevated privileges
# Generate JWT with role 'service_role' using GOTRUE_JWT_SECRET
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# =============================================================================
# Next.js Application Configuration
# =============================================================================

# Supabase API URL (accessed via Caddy reverse proxy)
NEXT_PUBLIC_SUPABASE_URL=http://localhost/api

# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost

# Anonymous key (must match SUPABASE_ANON_KEY above)
# This is duplicated for Next.js environment
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Encryption key for AI API keys (Story 1.6)
# Generate with: openssl rand -base64 32
# IMPORTANT: Must be consistent across deployments for decryption to work
ENCRYPTION_KEY=your_encryption_key_here_minimum_32_characters

# =============================================================================
# Caddy Reverse Proxy Configuration
# =============================================================================

# Domain name (use 'localhost' for local development)
# For production, set to your actual domain: easyping.example.com
DOMAIN=localhost

# TLS/SSL Email for Let's Encrypt notifications
# Leave empty for localhost (will use self-signed certificate)
TLS_EMAIL=

# =============================================================================
# Security Warnings
# =============================================================================
#
# ⚠️  IMPORTANT SECURITY NOTES:
#
# 1. DO NOT use default passwords in production!
# 2. DO NOT commit .env file with real secrets to Git!
# 3. Generate strong, unique passwords for each secret
# 4. Rotate JWT secrets regularly (every 90 days recommended)
# 5. Use different secrets for development and production
# 6. Store production secrets in a secure vault (e.g., 1Password, Vault)
# 7. Limit access to .env file using file permissions: chmod 600 .env
# 8. Enable SMTP for email verification in production
# 9. Configure firewall rules to restrict database access
# 10. Use strong TLS ciphers and keep Caddy updated
#
# =============================================================================

# =============================================================================
# How to Generate Secure Secrets
# =============================================================================
#
# PostgreSQL Password (32 characters):
#   openssl rand -base64 32
#
# JWT Secret (32 characters minimum):
#   openssl rand -base64 32
#
# Realtime Secret Key Base (64 characters):
#   openssl rand -base64 64
#
# Generate Supabase API Keys:
#   1. Use JWT Secret as signing key
#   2. Generate token for role 'anon' (anonymous key)
#   3. Generate token for role 'service_role' (service key)
#   4. Tool: https://jwt.io or https://supabase.com/docs/guides/hosting/overview#api-keys
#
# Example JWT Payload for Anonymous Key:
#   {
#     "role": "anon",
#     "iss": "supabase",
#     "iat": 1641769200,
#     "exp": 1799535600
#   }
#
# Example JWT Payload for Service Role Key:
#   {
#     "role": "service_role",
#     "iss": "supabase",
#     "iat": 1641769200,
#     "exp": 1799535600
#   }
#
# =============================================================================
