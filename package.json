{
  "name": "easyping",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-native, chat-first service desk",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "analyze": "ANALYZE=true pnpm --filter=@easyping/web build",
    "lighthouse": "lhci autorun",
    "prepare": "husky",
    "supabase:start": "pnpm --filter=@easyping/database supabase:start",
    "supabase:stop": "pnpm --filter=@easyping/database supabase:stop",
    "db:reset": "pnpm --filter=@easyping/database supabase:reset",
    "db:migrate": "pnpm --filter=@easyping/database db:migrate",
    "db:types": "pnpm --filter=@easyping/database db:types",
    "db:seed": "pnpm --filter=@easyping/database db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@lhci/cli": "^0.15.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
