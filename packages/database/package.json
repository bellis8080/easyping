{
  "name": "@easyping/database",
  "version": "0.1.0",
  "private": true,
  "description": "Supabase migrations and database schemas",
  "main": "index.js",
  "scripts": {
    "typecheck": "echo 'No TypeScript in database package'",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --local > ../types/src/supabase.ts",
    "db:seed": "supabase db reset"
  },
  "devDependencies": {
    "supabase": "^2.53.6"
  }
}
